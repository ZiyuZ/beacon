# Shared secret required by `POST /api/log` and `GET /api/...`.
# Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
BEACON_API_TOKEN=change-me

# Where the SQLite file lives inside the container.
# Override only if you mount a different volume path.
BEACON_SQLITE_PATH=/app/data/beacon.db

# Seconds without new logs before a task is considered "inactive".
BEACON_RUNNING_WINDOW_S=30
